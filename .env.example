# Actual Budget Configuration
# Your Actual Budget server URL (use http://localhost:5006 for local server)
ACTUAL_SERVER_URL=http://localhost:5006

# Your Actual Budget password (leave empty if no password set)
ACTUAL_PASSWORD=

# Your budget ID (find in Settings > Advanced in Actual Budget)
ACTUAL_BUDGET_ID=

# Directory for Actual Budget local data
ACTUAL_DATA_DIR=./data

# Extension Configuration
# How often to update stock prices (in minutes)
UPDATE_INTERVAL_MINUTES=60

# Where to store portfolio data
PORTFOLIO_FILE=./portfolio.json

# Stock exchange suffix appended to bare tickers (default .SW for SIX Swiss Exchange)
# Other examples: .DE (XETRA), .L (London), .PA (Paris), .AS (Amsterdam)
STOCK_EXCHANGE_SUFFIX=.SW

# Web UI password — when set, enables HTTP Basic Auth on the web interface.
# Leave empty (or unset) to disable authentication (fine for a trusted LAN).
WEB_PASSWORD=
